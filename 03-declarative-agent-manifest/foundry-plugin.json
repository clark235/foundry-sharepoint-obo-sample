{
  "openapi": "3.0.1",
  "info": {
    "title": "Foundry Analysis Action",
    "description": "Calls Azure AI Foundry agent for custom analysis",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "https://your-foundry-endpoint.azurewebsites.net" }
  ],
  "paths": {
    "/analyze": {
      "post": {
        "operationId": "analyzeContent",
        "summary": "Analyze SharePoint content with custom AI logic",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": { "type": "string", "description": "The user's original question" },
                  "context": { "type": "string", "description": "SharePoint content retrieved by M365 Copilot" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analysis result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "analysis": { "type": "string" },
                    "confidence": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
