# ============================================================================
# Foundry Endpoint — Environment Variables
# ============================================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================================

# --- Azure AI Foundry ---
# Your Foundry project endpoint (from the Foundry portal → project → Overview)
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# The agent ID created in your Foundry project (starts with "asst_")
FOUNDRY_AGENT_ID=asst_xxxxxxxxxxxxxxxxxxxx

# Maximum seconds to wait for the Foundry agent to respond (default: 90)
FOUNDRY_TIMEOUT_SECONDS=90

# --- Entra ID (for bearer token validation) ---
# Your Azure AD / Entra tenant ID
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# The app registration client ID that protects this endpoint
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# --- Identity ---
# Set to "true" when running on Azure with system-assigned managed identity
# Set to "false" (default) for local development with az login
USE_MANAGED_IDENTITY=false
